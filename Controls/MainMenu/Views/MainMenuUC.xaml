<UserControl x:Class="WinForm.Controls.MainMenu.Views.MainMenuUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WinForm.Controls.MainMenu.Views"
             xmlns:views="clr-namespace:WinForm.Controls.MainMenu.Views"
             xmlns:vm="clr-namespace:WinForm.Controls.MainMenu.ViewModels"
             mc:Ignorable="d" 
             x:Name="MainMenuRoot"
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.DataContext>
        <vm:MainMenuViewModel />
    </UserControl.DataContext>

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#BDC3C7" BorderThickness="0,0,0,1" Background="#FFFFFF">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <views:TopMenuUC Grid.Column="0" 
                                 VerticalAlignment="Center" 
                                 Margin="5,0,10,0"/>

                <views:SearchBarUC Grid.Column="1" 
                                   VerticalAlignment="Center" 
                                   Margin="15,5,5,5"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <views:LeftMenuUC Grid.Column="0"/>

            <views:MainContentUC Grid.Column="1"/>
        </Grid>
    </Grid>
    
</UserControl>
